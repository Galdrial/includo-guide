# Core
PORT=3001
OPENAI_API_KEY=your_openai_api_key_here

# Admin ingest protection
ADMIN_INGEST_TOKEN=change_this_with_a_long_random_secret

# Session storage (anonymous sessions)
SESSIONS_DIR=./data
SESSION_TTL_MS=2592000000
SESSION_PRUNE_INTERVAL_MS=600000
MAX_SESSION_MESSAGES=20

# Ingest endpoint rate limiting
INGEST_RATE_LIMIT_WINDOW_MS=900000
INGEST_RATE_LIMIT_MAX=10
